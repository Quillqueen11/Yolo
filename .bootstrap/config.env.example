# Quill Configuration Template
# Copy this to .env and fill in your values
# DO NOT commit .env to git (already in .gitignore)

# ===========================================
# API KEYS — REQUIRED
# ===========================================

# Primary AI API (Sumopod)
SUMOPOD_API_KEY=your_sumopod_api_key_here
SUMOPOD_BASE_URL=https://ai.sumopod.com

# Tavily Web Search (for enrichment)
TAVILY_API_KEY=tvly-dev-your_key_here

# Telegram Bot (for notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ===========================================
# USER CONFIG — REQUIRED
# ===========================================

# User chat ID (Telegram)
USER_CHAT_ID=924535843

# User name
USER_NAME=Andry

# Communication language
LANGUAGE=id  # Indonesian (default)

# ===========================================
# IDX MONITOR CONFIG — OPTIONAL
# ===========================================

# IDX API base
IDX_BASE_URL=https://www.idx.co.id/primary

# Monitor schedule (cron format)
MONITOR_SCHEDULE="0 6-22/2 * * *"  # Every 2 hours, 6AM-10PM WIB

# ===========================================
# CHROMA DB — OPTIONAL
# ===========================================

# Path to Chroma database
CHROMA_DB_PATH=/path/to/chroma_db

# ===========================================
# SURVIVAL MODE — OPTIONAL
# ===========================================

# Backup destination
BACKUP_DEST=/path/to/backups

# Backup retention (days)
BACKUP_RETENTION=14

# ===========================================
# VPS INFO — REQUIRED FOR RECOVERY
# ===========================================

# VPS IP (for remote recovery)
VPS_IP=your_vps_ip_here

# SSH port
SSH_PORT=22

# SSH username
SSH_USER=root
